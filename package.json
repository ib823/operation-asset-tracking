{
  "name": "oat",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @oat/app dev",
    "build": "pnpm --filter @oat/app build",
    "start": "pnpm --filter @oat/app start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "db:migrate": "pnpm --filter @oat/db migrate:dev",
    "db:deploy": "pnpm --filter @oat/db migrate:deploy",
    "db:generate": "pnpm --filter @oat/db generate",
    "db:seed": "pnpm --filter @oat/db seed",
    "licences": "node scripts/check-licences.mjs",
    "sbom": "node scripts/generate-sbom.mjs",
    "db:reset-data": "pnpm --filter @oat/db reset:data"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "globals": "^17.7.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
