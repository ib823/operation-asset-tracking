{
  "name": "Lablink OAT",
  "dockerComposeFile": "../infra/docker-compose.yml",
  // Attach to postgres and develop against it, rather than running the app container:
  // in a Codespace you want the app on the host with hot reload, but a real Postgres.
  "service": "postgres",
  "workspaceFolder": "/workspaces/operation-asset-tracking",
  "overrideCommand": true,
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "Prisma.prisma",
        "ms-playwright.playwright"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  "forwardPorts": [3000, 5432],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "node"
}
