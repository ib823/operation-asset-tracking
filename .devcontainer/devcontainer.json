{
  "name": "Lablink OAT",
  "dockerComposeFile": "../infra/docker-compose.yml",
  // Attach to the app service: its image is node:22-alpine, so Node 22 + pnpm (via corepack)
  // are already present. Attaching to postgres instead left the dev container on an Alpine
  // image with no Node, and the node devcontainer feature does not support Alpine ("Linux
  // distro alpine not supported"), which failed creation and dropped Codespaces to recovery.
  // Postgres still comes up as a compose dependency, so we develop against a real database.
  "service": "app",
  "workspaceFolder": "/workspaces/operation-asset-tracking",
  // Do not run the app's production CMD (migrate-then-start); keep the dev container idle so
  // we drive pnpm dev / tests / compose ourselves.
  "overrideCommand": true,
  // No Features on this Alpine image. The node feature is Alpine-incompatible; the git
  // Feature is a bash script and node:22-alpine has no bash, so it exits 127 and fails the
  // build. git + bash are installed in the runtime image via apk instead (infra/Dockerfile).
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "Prisma.prisma",
        "ms-playwright.playwright"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  "forwardPorts": [3000, 5432],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  // Keep user-globally installed CLIs (Claude Code — see post-create.sh) on PATH across
  // rebuilds/reconnects. Dev-container-only; does not affect the app image or its runtime.
  "remoteEnv": {
    "PATH": "/home/node/.npm-global/bin:${containerEnv:PATH}"
  },
  "remoteUser": "node"
}
