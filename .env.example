# Copy to .env and adjust. Never commit .env — it is gitignored.

# Postgres. In docker-compose the host is `postgres`; locally it is `localhost`.
DATABASE_URL="postgresql://oat:oat_dev_password@localhost:5432/oat"

# Compose-only: credentials the postgres container is created with.
POSTGRES_USER="oat"
POSTGRES_PASSWORD="oat_dev_password"
POSTGRES_DB="oat"
POSTGRES_PORT="5432"
APP_PORT="3000"

# Auth.js session signing secret. REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# REQUIRED behind a proxy or in any non-localhost deployment. Without it Auth.js throws
# UntrustedHost in production. That error is thrown INSIDE middleware, where Next swallows it
# and renders the page anyway — i.e. it fails OPEN. Pages enforce their own access so this
# cannot expose data (ADR-0012), but set it regardless.
# Alternatively set AUTH_URL to the canonical external URL.
AUTH_TRUST_HOST="true"

# Hosts allowed to invoke Server Actions — REQUIRED behind a reverse proxy or load balancer.
# Next compares the browser's `origin` against `x-forwarded-host` and aborts if they differ.
# Without this, every form in the app fails with "Invalid Server Actions request".
# Comma-separated, host only (no protocol, no path). Leave empty for a direct localhost hit.
#   e.g. OAT_ALLOWED_ORIGINS="oat.lablink.example,oat-staging.lablink.example"
OAT_ALLOWED_ORIGINS=""

# Token for MACHINE callers only: the scheduler's idle sweep and connector polls. Those have
# no session and no person behind them. Human access uses Auth.js sessions + RBAC, never this.
# Unset means service endpoints are DISABLED (they fail closed, returning 503).
OAT_SERVICE_TOKEN=""

# Password used by the seed for demo users. Development only.
OAT_SEED_PASSWORD="devpassword123"

# Connector feature flags. Every connector is optional and off unless enabled here.
# `scan` is the fallback floor and should stay on — it is what keeps the register
# usable when no automated source is available.
OAT_CONNECTOR_SCAN="1"
OAT_CONNECTOR_SOTI="0"
# NOTE: these flags also decide which classes get utilisation rollups (ADR-0015). A class is
# only rolled up when a connector feeding it is enabled — so lab instruments report NO
# utilisation until OAT_CONNECTOR_LIS is on and a real LIS feed exists. That gap is
# deliberate: an honest "not measured" beats a fabricated 100%.
OAT_CONNECTOR_OSQUERY="0"
OAT_CONNECTOR_SNMP="0"
OAT_CONNECTOR_LIS="0"

# The scheduler runs as its OWN process (ADR-0020), not inside the app:
#   pnpm --filter @oat/jobs start
# docker-compose starts it as the `worker` service. It drives connector polls, the idle sweep
# (which also expires scan TTLs) and the nightly rollup — idleness accrues BECAUSE nothing is
# reported, so without it nothing ever discovers it.
# Not started by `pnpm dev`: a cron mutating state under a test suite asserting exact counts
# turns real failures into apparent flakes.

# osquery / Fleet. Leave unset to use the mock — a Fleet instance is a Lablink dependency.
OAT_FLEET_BASE_URL=""
OAT_FLEET_API_TOKEN=""
OAT_FLEET_QUERY_NAME="oat_endpoint_idle"

# SNMP targets: TAG@host[:port], comma-separated. Unset means no devices are polled, which is
# the correct "not deployed" behaviour — there is no mock, because inventing fake printers
# would only fabricate utilisation.
#   e.g. OAT_SNMP_TARGETS="LAB-0005@10.1.2.3,LAB-0011@10.1.2.4"
OAT_SNMP_TARGETS=""
OAT_SNMP_COMMUNITY="public"

# LIS (HL7/ASTM) — client dependency C4. The connector is an interface stub; setting this
# does nothing until it is implemented. Instrument utilisation reports "not measured" until
# then, by design (ADR-0008).
OAT_LIS_ENDPOINT=""

# SAP client. "mock" is the only implementation until a tenant exists (assumption A2).
OAT_SAP_CLIENT="mock"

# SOTI MobiControl. Leave unset to use the mock adapter — a real tenant is a Lablink/vendor
# dependency. Set all three and the real connector is used instead; nothing else changes.
OAT_SOTI_BASE_URL=""
OAT_SOTI_CLIENT_ID=""
OAT_SOTI_CLIENT_SECRET=""
# Optional: per-tenant basic-auth realm token, and a device path to restrict the poll to.
OAT_SOTI_TENANT_TOKEN=""
OAT_SOTI_PATH=""
